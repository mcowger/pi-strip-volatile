{
	"name": "pi-ext-CHANGEME",
	"version": "0.1.0",
	"description": "A pi.dev extension",
	"keywords": ["pi-package", "pi-extension"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vegardx/pi-ext-CHANGEME.git"
	},
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"pi": {
		"extensions": ["./index.ts"]
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@mariozechner/pi-coding-agent": "^0.68.1",
		"@sinclair/typebox": "^0.34.49",
		"typescript": "^6.0.3",
		"vitest": "^3.2.4"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"check": "npm run lint && npm run typecheck && npm run test"
	}
}
