{
	"name": "strip-volatile",
	"version": "0.1.0",
	"description": "A pi extension that prevents volatile runtime data from being persisted to settings.json",
	"keywords": ["pi-package", "pi-extension"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mcowger/strip-volatile.git"
	},
	"type": "module",
	"engines": {
		"bun": ">=1.0"
	},
	"pi": {
		"extensions": ["./index.ts"]
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"@biomejs/biome": "^2.4.13",
		"@mariozechner/pi-coding-agent": "latest",
		"typescript": "^6.0.3",
		"vitest": "latest"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"check": "bun run lint && bun run typecheck && bun run test"
	}
}
